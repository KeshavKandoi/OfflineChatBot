{
  "name": "offline-ai",
  "version": "1.0.0",
  "description": "Offline AI Chatbot",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.offlineai.app",
    "productName": "Offline AI",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "identity": null,
      "icon": "icon.icns"
    },
    "files": [
      "main.js",
      "setup.html"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/dist/**",
          "!**/build/**",
          "!**/*.pyc"
        ]
      },
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      },
      {
        "from": "binaries",
        "to": "binaries"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Offline AI"
    }
  },
  "devDependencies": {
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12"
  }
}